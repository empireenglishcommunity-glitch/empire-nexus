# n8n-MCP Server — Environment Variables
# Copy to .env on the server at /opt/n8n-mcp/.env
# NEVER commit the .env file (it's in .gitignore)

# Your n8n instance API URL
N8N_API_URL=https://bot.empireenglish.online/api/v1

# n8n API Key (generate from n8n Settings → API → Create API Key)
N8N_API_KEY=your-n8n-api-key-here
