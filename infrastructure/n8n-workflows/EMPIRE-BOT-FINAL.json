    {
      "parameters": {
        "jsCode": "const c=$('Code Router').first().json;const text='❓ السؤال 1/7\\n\\nكيف تصف إنجليزيتك اليوم؟';const kb=JSON.stringify({inline_keyboard:[[{text:'أعرف حروف/كلمات بسيطة فقط',callback_data:'q1_0'}],[{text:'أكوّن جُمل بسيطة بصعوبة',callback_data:'q1_1'}],[{text:'أتعامل مع محادثات يومية',callback_data:'q1_2'}],[{text:'أتحدث بطلاقة عن معظم المواضيع',callback_data:'q1_3'}]]});return[{json:{chat_id:c.chat_id,text,reply_markup:kb}}];"
