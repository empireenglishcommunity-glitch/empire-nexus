    {
      "parameters": {
        "jsCode": "const u=$input.first().json;let route='unknown',chat_id='',first_name='',telegram_id='',username='',cb='';\nif(u.callback_query){cb=(u.callback_query.data||'').trim();chat_id=u.callback_query.message.chat.id;first_name=u.callback_query.from.first_name||'';telegram_id=String(u.callback_query.from.id);username=u.callback_query.from.username||'';route=cb.match(/^q\\d+_/)?'quiz_answer':cb.toLowerCase();}else if(u.message){const t=(u.message.text||'').trim();chat_id=u.message.chat.id;first_name=u.message.from.first_name||'';telegram_id=String(u.message.from.id);username=u.message.from.username||'';route=(t==='/start'||t==='/menu')?'start':t==='/stop'?'stop':'unknown';}\nreturn[{json:{_route:route,chat_id:Number(chat_id),first_name,telegram_id,username,callback_data:cb}}];"
      },
      "id": "r1",
      "name": "Code Router",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 580]
    },
    {
      "parameters": {
        "rules": { "values": [

          {"conditions":{"options":{"caseSensitive":false},"conditions":[{"leftValue":"={{ $json._route }}","rightValue":"start","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"Start"},
          {"conditions":{"options":{"caseSensitive":false},"conditions":[{"leftValue":"={{ $json._route }}","rightValue":"quiz","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"Quiz"},
          {"conditions":{"options":{"caseSensitive":false},"conditions":[{"leftValue":"={{ $json._route }}","rightValue":"quiz_answer","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"QuizAnswer"},
          {"conditions":{"options":{"caseSensitive":false},"conditions":[{"leftValue":"={{ $json._route }}","rightValue":"resource","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"Resource"},
          {"conditions":{"options":{"caseSensitive":false},"conditions":[{"leftValue":"={{ $json._route }}","rightValue":"how","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"How"},
          {"conditions":{"options":{"caseSensitive":false},"conditions":[{"leftValue":"={{ $json._route }}","rightValue":"call","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"Call"},
          {"conditions":{"options":{"caseSensitive":false},"conditions":[{"leftValue":"={{ $json._route }}","rightValue":"community","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"Community"},
          {"conditions":{"options":{"caseSensitive":false},"conditions":[{"leftValue":"={{ $json._route }}","rightValue":"menu","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"Menu"}
        ]},
        "options": {"fallbackOutput":"none"}
      },
