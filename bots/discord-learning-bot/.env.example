# Empire English Community Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# === REQUIRED ===
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_server_id_here

# === AI (at least one required) ===
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=

# === GOOGLE SHEETS CRM ===
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your_private_key_here
SHEET_ID=your_google_sheet_id_here
SHEET_GID_SUBSCRIBERS=0
SHEET_GID_EVENTS=0

# === SCHEDULING ===
DAILY_TASK_HOUR=6
TIMEZONE=Asia/Dubai

# === PRACTICE PLATFORM (optional — has a working default) ===
# Web-based daily practice pages (empireenglishcommunity-glitch/empire-practice).
# Defaults to the live Cloudflare Pages URL if unset. Switch to
# https://practice.empireenglish.online once its DNS/SSL is confirmed live.
PRACTICE_PLATFORM_URL=https://empire-practice-8l0.pages.dev

# === TELEGRAM ALERTS (optional) ===
TELEGRAM_ALERT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=your_telegram_chat_id_here

# === OPERATIONAL ===
BOT_PREFIX=!
LOG_LEVEL=INFO
