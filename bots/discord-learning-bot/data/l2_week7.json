  "speaking_missions": {
    "Saturday": {
      "type": "debate",
      "prompt": "Debate: 'Solo travel is more rewarding than traveling with others.' Argue for ONE side with 2 examples.",
      "target_seconds": 190
    },
    "Sunday": {
      "type": "presentation",
      "prompt": "Give a 3-minute presentation about your dream destination — why you want to go, what you'd do there, and what makes it special.",
      "target_seconds": 190
    },
    "Monday": {
      "type": "analysis",
      "prompt": "Analyze why some travelers prefer guided tours while others prefer to explore independently. Discuss at least 2 factors.",
      "target_seconds": 190
    },
    "Tuesday": {
      "type": "storytelling",
      "prompt": "Tell a detailed story about a trip that didn't go as planned — what happened, and how did you handle it?",
      "target_seconds": 190
    },
    "Wednesday": {
      "type": "interview",
      "prompt": "Imagine you're a travel blogger being interviewed. Answer: What's the most memorable place you've visited? What's one travel mistake beginners make? What's your best travel tip?",
      "target_seconds": 190
    },
    "Thursday": {
      "type": "summary",
      "prompt": "Summarize a travel video, article, or someone's story about a trip they took, in under 2 minutes.",
      "target_seconds": 190
    },
    "Friday": {
      "type": "free_discussion",
      "prompt": "Discuss freely for 4 minutes: is it better to visit many places briefly, or fewer places deeply? Why?",
      "target_seconds": 190
    }
  },
  "writing_prompts": [
    "Write an essay (150+ words) arguing whether budget travel or luxury travel gives a more meaningful experience.",
