  "speaking_missions": {
    "Saturday": {
      "type": "debate",
      "prompt": "Debate: 'The ends justify the means' — is it ever acceptable to do something wrong for a good outcome? Argue for ONE side with 2 examples.",
      "target_seconds": 190
    },
    "Sunday": {
      "type": "presentation",
      "prompt": "Give a 3-minute presentation about a personal principle or value you refuse to compromise on, and why.",
      "target_seconds": 190
    },
    "Monday": {
      "type": "analysis",
      "prompt": "Analyze why different cultures sometimes have very different ideas of what's 'right' and 'wrong'. Discuss at least 2 possible explanations.",
      "target_seconds": 190
    },
    "Tuesday": {
      "type": "storytelling",
      "prompt": "Tell a detailed story about a time you faced a difficult ethical decision — what did you choose, and would you choose the same again?",
      "target_seconds": 190
    },
    "Wednesday": {
      "type": "interview",
      "prompt": "Imagine you're a philosopher being interviewed about the meaning of a good life. Answer: What makes a life 'good' or 'meaningful'? Is happiness the ultimate goal? What's one common misconception about ethics?",
      "target_seconds": 190
    },
    "Thursday": {
      "type": "summary",
      "prompt": "Summarize a philosophical idea, article, or discussion you've encountered, in under 2 minutes, in plain language.",
      "target_seconds": 190
    },
    "Friday": {
      "type": "free_discussion",
      "prompt": "Discuss freely for 4 minutes: is it possible to be a completely objective, unbiased person? Why or why not?",
      "target_seconds": 190
    }
  },
  "writing_prompts": [
    "Write an essay (150+ words) arguing whether morality is universal or relative to each culture.",
    "Analyze a well-known ethical dilemma (real or hypothetical) and explain what you would do and why.",
    "Compare two different philosophical approaches to happiness (for example, pleasure-seeking versus purpose-seeking).",
    "Write a formal email to a philosophy professor or public thinker asking a genuine question about ethics.",
    "Describe a personal experience that made you rethink your own values or beliefs (200+ words).",
    "What changes would you make to how ethics is taught or discussed in schools? Explain at least 2 specific ideas.",
    "Summarize a philosophical concept or argument in your own words, in under 150 words, using a concrete example to explain it."
