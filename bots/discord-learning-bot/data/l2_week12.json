  "speaking_missions": {
    "Saturday": {
      "type": "debate",
      "prompt": "Debate: 'Automation and AI will create more jobs than they destroy.' Argue for ONE side with 2 examples.",
      "target_seconds": 190
    },
    "Sunday": {
      "type": "presentation",
      "prompt": "Give a 3-minute presentation predicting what daily life will look like in 20 years, focusing on one specific area (work, home, transportation, etc.).",
      "target_seconds": 190
    },
    "Monday": {
      "type": "analysis",
      "prompt": "Analyze the risks and benefits of relying more heavily on AI in decision-making (healthcare, hiring, justice, etc.). Discuss at least 2 points.",
      "target_seconds": 190
    },
    "Tuesday": {
      "type": "storytelling",
      "prompt": "Tell a detailed story about a piece of technology that changed how you live, work, or communicate.",
      "target_seconds": 190
    },
    "Wednesday": {
      "type": "interview",
      "prompt": "Imagine you're a futurist being interviewed about upcoming technology. Answer: What technology will have the biggest impact in the next decade? What worries you about it? What excites you about it?",
      "target_seconds": 190
    },
    "Thursday": {
      "type": "summary",
      "prompt": "Summarize an article or video about an emerging technology, in under 2 minutes, including your own opinion on it.",
      "target_seconds": 190
    },
    "Friday": {
      "type": "free_discussion",
      "prompt": "Discuss freely for 4 minutes: is there a piece of technology you deliberately avoid using, or wish existed but doesn't yet? Explain.",
      "target_seconds": 190
    }
  },
  "writing_prompts": [
    "Write an essay (150+ words) arguing whether society is moving toward technology too quickly or not quickly enough.",
    "Analyze how a specific emerging technology (AI, VR, biotech, etc. — choose one) might change one industry within the next decade.",
    "Compare life today with life 20 years ago in terms of technology's role in daily routines.",
    "Write a formal email proposing a new technology-based solution to a problem in your community.",
