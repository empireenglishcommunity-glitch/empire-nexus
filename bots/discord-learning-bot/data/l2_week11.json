  "speaking_missions": {
    "Saturday": {
      "type": "debate",
      "prompt": "Debate: 'Social media influencers should be held to the same standards as professional journalists.' Argue for ONE side with 2 examples.",
      "target_seconds": 190
    },
    "Sunday": {
      "type": "presentation",
      "prompt": "Give a 3-minute presentation about how you personally decide whether a news source is trustworthy.",
      "target_seconds": 190
    },
    "Monday": {
      "type": "analysis",
      "prompt": "Analyze why clickbait headlines are so effective, and what harm (if any) they cause. Discuss at least 2 points.",
      "target_seconds": 190
    },
    "Tuesday": {
      "type": "storytelling",
      "prompt": "Tell a detailed story about a time you believed something from the media that later turned out to be false or exaggerated.",
      "target_seconds": 190
    },
    "Wednesday": {
      "type": "interview",
      "prompt": "Imagine you're an investigative journalist being interviewed. Answer: What story are you most proud of covering? What risks does investigative journalism involve? Why does this work matter?",
      "target_seconds": 190
    },
    "Thursday": {
      "type": "summary",
      "prompt": "Summarize a media controversy or journalism-related story you've heard about, in under 2 minutes.",
      "target_seconds": 190
    },
    "Friday": {
      "type": "free_discussion",
      "prompt": "Discuss freely for 4 minutes: has social media made journalism better, worse, or just different? Explain your view.",
      "target_seconds": 190
    }
  },
  "writing_prompts": [
    "Write an essay (150+ words) arguing whether social media companies should be responsible for the content people post.",
    "Analyze how the ownership of a media outlet (who owns it, who funds it) might affect what it reports.",
    "Compare traditional newspapers with online news sources in terms of reliability and speed.",
    "Write a formal email to a news outlet pointing out what you believe is an error or bias in one of their articles.",
    "Describe a personal experience of encountering misinformation and how you figured out it wasn't true (200+ words).",
    "What changes would you make to how news is regulated or verified online? Explain at least 2 specific ideas.",
    "Summarize a media literacy tip or fact-checking method in your own words, in under 150 words."
  ]
