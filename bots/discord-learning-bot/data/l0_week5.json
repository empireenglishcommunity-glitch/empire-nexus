  "speaking_missions": {
    "Saturday": {"type": "self_introduction", "prompt": "Talk about food: 'I like ___. I don't like ___. My favorite food is ___.'", "target_seconds": 40},
    "Sunday": {"type": "describe", "prompt": "Describe what you ate today. What did you have for breakfast and lunch?", "target_seconds": 40},
    "Monday": {"type": "list_count", "prompt": "You're at a restaurant. Order food: 'I would like ___. Do you have ___? How much is ___?'", "target_seconds": 45},
    "Tuesday": {"type": "read_aloud", "prompt": "Read: 'Do you like coffee? I prefer tea. How much does the bread cost? I need some fruit and vegetables. The chicken is delicious.'", "target_seconds": 30},
    "Wednesday": {"type": "answer_questions", "prompt": "Answer: What is your favorite food? Do you cook? What do you usually eat for dinner?", "target_seconds": 45},
    "Thursday": {"type": "shadow_repeat", "prompt": "Repeat 3 times: 'I would like some water please. How much does this cost? Do you have any fresh fruit?'", "target_seconds": 30},
    "Friday": {"type": "free_talk", "prompt": "Talk about shopping: Where do you buy food? What do you buy? Is it expensive or cheap?", "target_seconds": 50}
