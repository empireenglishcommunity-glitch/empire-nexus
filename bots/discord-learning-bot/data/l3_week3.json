  "speaking_missions": {
    "Saturday": {
      "type": "TED_talk",
      "prompt": "Give a 5-minute TED-style talk presenting a research finding (real or hypothetical) as if to an academic conference audience, using formal academic vocabulary.",
      "target_seconds": 250
    },
    "Sunday": {
      "type": "debate_advanced",
      "prompt": "Structured debate with rebuttals: 'Qualitative research is more valuable than quantitative research, or the reverse.' Present your case with academic framing, then respond to a counter-argument.",
      "target_seconds": 250
    },
    "Monday": {
      "type": "podcast",
      "prompt": "Record a 5-minute podcast segment summarizing and critically analyzing a study or article you've read, identifying its methodology and one limitation.",
      "target_seconds": 250
    },
    "Tuesday": {
      "type": "teaching",
      "prompt": "Teach a beginner-level student the difference between paraphrasing and plagiarism, with a clear example of each.",
      "target_seconds": 250
    },
    "Wednesday": {
      "type": "improvisation",
      "prompt": "Respond to this unexpected prompt: defend a hypothesis on the spot, using at least one piece of 'empirical evidence' (real or invented for practice) to substantiate it.",
      "target_seconds": 250
    },
    "Thursday": {
      "type": "accent_mimicry",
      "prompt": "Find a short clip (30-60 seconds) of an academic lecture or conference talk. Mimic the speaker's formal register, pacing, and pronunciation of academic vocabulary.",
      "target_seconds": 250
    },
    "Friday": {
      "type": "free_mastery",
      "prompt": "Speak naturally for 5+ minutes presenting your own critical analysis of any topic, using at least 5 pieces of academic vocabulary from this week naturally.",
      "target_seconds": 250
    }
  },
  "writing_prompts": [
    "Write a persuasive essay (300+ words, using rhetorical devices) arguing for a specific research methodology's superiority in a field of your choice.",
    "Write a critical analysis of a study, article, or book, identifying its underlying assumptions and evaluating its evidence.",
    "Compose a formal report with recommendations based on a hypothetical set of findings in a field you're interested in.",
    "Write a creative piece (story or poem) that explores the tension between empirical evidence and personal belief.",
    "Draft an opinion column for an academic newsletter about the importance (or overemphasis) of citations and peer review.",
    "Write a comparison essay using academic vocabulary contrasting two theories, methods, or schools of thought in any field.",
    "Write freely about your own experience with academic writing — focus on style, not just content."
  ]
