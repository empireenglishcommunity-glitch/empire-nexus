    "Monday": {"type": "list_count", "prompt": "List 5 things you did last week using -ed verbs: worked, studied, played, etc.", "target_seconds": 55},
    "Tuesday": {"type": "read_aloud", "prompt": "Read: 'Yesterday I was tired because I worked a lot. But I was happy because I studied English. Last week I visited my friend. We played together and it was wonderful.'", "target_seconds": 35},
    "Wednesday": {"type": "answer_questions", "prompt": "Answer: How do you feel today? What did you do yesterday? What was the best day last week and why?", "target_seconds": 55},
    "Thursday": {"type": "shadow_repeat", "prompt": "Repeat 3 times: 'I was nervous but now I feel confident. Yesterday was interesting because I learned something new. I think English is difficult but I enjoy it.'", "target_seconds": 35},
    "Friday": {"type": "free_talk", "prompt": "THE FINAL FREE TALK: Talk for 60 seconds about ANYTHING. Your life, your feelings, your week, your goals. Show everything you've learned!", "target_seconds": 60}
