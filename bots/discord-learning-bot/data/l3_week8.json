  "speaking_missions": {
    "Saturday": {
      "type": "TED_talk",
      "prompt": "Give a 5-minute TED-style talk on 'What fluency actually means to me now, compared to when I started this journey.'",
      "target_seconds": 250
    },
    "Sunday": {
      "type": "debate_advanced",
      "prompt": "Structured debate with rebuttals: 'True fluency requires sounding native, or fluency is about effective communication regardless of accent.' Present your case, then respond to a counter-argument.",
      "target_seconds": 250
    },
    "Monday": {
      "type": "podcast",
      "prompt": "Record a 5-minute podcast segment reflecting on your entire learning journey from Level 0 to Level 3 — what surprised you, what was hardest, and what you're proudest of.",
      "target_seconds": 250
    },
    "Tuesday": {
      "type": "teaching",
      "prompt": "Teach a Level 1 or Level 2 student the single most important lesson you've learned about achieving fluency, in your own words.",
      "target_seconds": 250
    },
    "Wednesday": {
      "type": "improvisation",
      "prompt": "Respond to this unexpected prompt: switch registers on the spot — explain the same simple idea first very formally (as if to a professor), then very casually (as if to a close friend).",
      "target_seconds": 250
    },
    "Thursday": {
      "type": "accent_mimicry",
      "prompt": "Choose your own favorite native-speaker clip from anything you've watched this month, and deliver your best, most natural mimicry of it yet.",
      "target_seconds": 250
    },
    "Friday": {
      "type": "free_mastery",
      "prompt": "Speak naturally for 5+ minutes on any topic — this is your final Level 3 free-speech checkpoint. Speak as your genuine, fluent self, without worrying about perfection.",
      "target_seconds": 250
    }
  },
  "writing_prompts": [
    "Write a persuasive essay (300+ words, using rhetorical devices) arguing what 'fluency' should actually mean as a learning goal.",
    "Write a critical analysis of your own growth from Level 0 to Level 3, using specific evidence (recordings, milestones, feedback) to support your reflection.",
    "Compose a formal report with recommendations for the Empire English Community program itself, based on your full experience as a student.",
    "Write a creative piece (story, essay, or poem) that captures what learning a new language at this level of depth has meant to you personally.",
    "Draft an opinion column about whether 'native-like' should even be the goal of language learning, or if it's a flawed standard.",
    "Write a comparison essay contrasting who you were as an English speaker at Level 0 with who you are now.",
    "Write freely, in your own natural voice and style, about anything you want — this is your final Level 3 writing piece, a true test of your own voice in English."
  ]
