  "speaking_missions": {
    "Saturday": {
      "type": "debate",
      "prompt": "Debate: 'Anyone can be an artist, or true artistic talent is something you're born with.' Argue for ONE side with 2 examples.",
      "target_seconds": 190
    },
    "Sunday": {
      "type": "presentation",
      "prompt": "Give a 3-minute presentation about an artist, song, movie, or piece of art that has influenced you personally.",
      "target_seconds": 190
    },
    "Monday": {
      "type": "analysis",
      "prompt": "Analyze why some art becomes famous while equally skilled work stays unknown. Discuss at least 2 factors.",
      "target_seconds": 190
    },
    "Tuesday": {
      "type": "storytelling",
      "prompt": "Tell a detailed story about a creative project you worked on (art, music, writing, or anything else) and how it turned out.",
      "target_seconds": 190
    },
    "Wednesday": {
      "type": "interview",
      "prompt": "Imagine you're an artist being interviewed about your work. Answer: What inspires your art? What's the hardest part of being creative for a living? What advice would you give a beginner?",
      "target_seconds": 190
    },
    "Thursday": {
      "type": "summary",
      "prompt": "Summarize a piece of art, film, or music you recently experienced, in under 2 minutes, including your own reaction to it.",
      "target_seconds": 190
    },
    "Friday": {
      "type": "free_discussion",
      "prompt": "Discuss freely for 4 minutes: should art always have a clear meaning, or is it okay for art to be confusing or open to interpretation?",
      "target_seconds": 190
    }
