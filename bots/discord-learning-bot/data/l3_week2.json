  "speaking_missions": {
    "Saturday": {
      "type": "TED_talk",
      "prompt": "Give a 5-minute TED-style talk on 'Why humor is one of the hardest things to translate between cultures.' Include at least one real example of a joke that doesn't translate well.",
      "target_seconds": 250
    },
    "Sunday": {
      "type": "debate_advanced",
      "prompt": "Structured debate with rebuttals: 'Sarcasm is a sign of intelligence, or sarcasm is just unkind humor.' Take a side, present your case, then respond to an imagined counter-argument.",
      "target_seconds": 250
    },
    "Monday": {
      "type": "podcast",
      "prompt": "Record a 5-minute podcast segment discussing the difference between dry humor, sarcasm, and self-deprecating humor, with an example of each from your own life.",
      "target_seconds": 250
    },
    "Tuesday": {
      "type": "teaching",
      "prompt": "Teach a beginner-level student how to recognize sarcasm in spoken English, using tone of voice as the main clue — give 2 example sentences that could be sincere OR sarcastic depending on delivery.",
      "target_seconds": 250
    },
    "Wednesday": {
      "type": "improvisation",
      "prompt": "Respond to this unexpected prompt: deliver a 3-minute deadpan, self-deprecating story about a mistake you made, using dry humor throughout without ever visibly laughing yourself.",
      "target_seconds": 250
    },
    "Thursday": {
      "type": "accent_mimicry",
      "prompt": "Find a short clip (30-60 seconds) of a native comedian or podcast host delivering a joke or sarcastic remark. Mimic their exact comic timing, pauses, and pitch shifts.",
      "target_seconds": 250
    },
    "Friday": {
      "type": "free_mastery",
      "prompt": "Speak naturally for 5+ minutes on any topic, deliberately including at least 2 genuine attempts at humor (a joke, a pun, or a witty observation) that feel natural, not forced.",
      "target_seconds": 250
    }
  },
  "writing_prompts": [
    "Write a persuasive essay (300+ words, using rhetorical devices) arguing whether humor should be taught as part of advanced language learning.",
    "Write a critical analysis of how sarcasm functions differently in written text (where tone is invisible) versus spoken conversation.",
    "Compose a formal report with recommendations for how comedy writers adapt jokes for international/multilingual audiences.",
    "Write a short humorous story or comedic monologue built around a single central pun or running joke.",
    "Draft an opinion column for a newspaper about whether internet culture has made sarcasm harder to detect in text-based communication.",
    "Write a comparison essay contrasting a type of humor common in your native culture with a type of humor common in American English-speaking culture.",
    "Write freely about a time humor or sarcasm was lost in translation for you (in either direction) — focus on style, not just content."
