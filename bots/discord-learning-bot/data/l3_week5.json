  "speaking_missions": {
    "Saturday": {
      "type": "TED_talk",
      "prompt": "Give a 5-minute TED-style talk that deliberately uses ethos, pathos, AND logos, and be ready to identify each technique afterward.",
      "target_seconds": 250
    },
    "Sunday": {
      "type": "debate_advanced",
      "prompt": "Structured debate with rebuttals on a topic of your choice. This week, deliberately identify and name any logical fallacy your opponent (real or imagined) might use, and rebut it directly.",
      "target_seconds": 250
    },
    "Monday": {
      "type": "podcast",
      "prompt": "Record a 5-minute podcast segment analyzing a persuasive speech or advertisement you've seen, identifying its rhetorical techniques and any fallacies used.",
      "target_seconds": 250
    },
    "Tuesday": {
      "type": "teaching",
      "prompt": "Teach a beginner-level student the difference between ethos, pathos, and logos with one clear, simple example of each.",
      "target_seconds": 250
    },
    "Wednesday": {
      "type": "improvisation",
      "prompt": "Respond to this unexpected prompt: deliver an impassioned, 2-minute persuasive plea for an unusual or silly cause (e.g., 'why pineapple belongs on pizza'), using real rhetorical techniques seriously.",
      "target_seconds": 250
    },
    "Thursday": {
      "type": "accent_mimicry",
      "prompt": "Find a short clip (30-60 seconds) of a famous persuasive speech (political, motivational, or a TED talk). Mimic the speaker's tone of conviction, pacing, and emphasis.",
      "target_seconds": 250
    },
    "Friday": {
      "type": "free_mastery",
      "prompt": "Speak naturally for 5+ minutes persuading someone (real or imagined) of a genuine opinion you hold, using at least 2 rhetorical devices from this week naturally.",
      "target_seconds": 250
    }
  },
  "writing_prompts": [
    "Write a persuasive essay (300+ words, deliberately using ethos, pathos, and logos) on a topic you feel strongly about.",
    "Write a critical analysis identifying the rhetorical techniques and any logical fallacies in a real speech, ad, or opinion article.",
    "Compose a formal report with recommendations for how a company or organization could communicate more persuasively and ethically.",
    "Write a creative piece (a satirical speech or dialogue) that exaggerates a common logical fallacy for comedic effect.",
    "Draft an opinion column that deliberately uses strong rhetorical framing to argue a controversial-but-safe topic (e.g., a hobby or food debate).",
    "Write a comparison essay contrasting a purely logical (logos-based) argument with a purely emotional (pathos-based) argument on the same topic.",
    "Write freely about a time you were persuaded (or failed to be persuaded) by a rhetorical technique — focus on style, not just content."
