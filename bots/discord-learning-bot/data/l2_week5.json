    },
    "Sunday": {
      "type": "presentation",
      "prompt": "Give a 3-minute presentation about a scientific breakthrough or piece of technology that fascinates you.",
      "target_seconds": 190
    },
    "Monday": {
      "type": "analysis",
      "prompt": "Analyze why some scientific discoveries take decades to become widely accepted. Discuss at least 2 factors.",
      "target_seconds": 190
    },
    "Tuesday": {
      "type": "storytelling",
      "prompt": "Tell a detailed story about a time technology surprised you, helped you, or frustrated you.",
      "target_seconds": 190
    },
    "Wednesday": {
      "type": "interview",
      "prompt": "Imagine you're a scientist being interviewed about your research. Answer: What are you researching? Why does it matter? What's the biggest obstacle you face?",
      "target_seconds": 190
    },
    "Thursday": {
      "type": "summary",
      "prompt": "Summarize a science article or documentary you've seen, in under 2 minutes, focusing on the main discovery and its significance.",
      "target_seconds": 190
    },
    "Friday": {
      "type": "free_discussion",
      "prompt": "Discuss freely for 4 minutes: if you could fund any single area of scientific research, what would it be and why?",
      "target_seconds": 190
    }
  },
  "writing_prompts": [
    "Write an essay (150+ words) arguing whether AI development should be slowed down or accelerated.",
