  "speaking_missions": {
    "Saturday": {
      "type": "TED_talk",
      "prompt": "Give a 5-minute TED-style talk on 'What I've learned about my own accent journey', reflecting on your progress from Level 0 to now.",
      "target_seconds": 250
    },
    "Sunday": {
      "type": "debate_advanced",
      "prompt": "Structured debate with rebuttals: 'Eliminating a foreign accent should be a goal for advanced learners, or accents are a natural, acceptable part of identity.' Present your case, then respond to a counter-argument.",
      "target_seconds": 250
    },
    "Monday": {
      "type": "podcast",
      "prompt": "Record a 5-minute podcast segment explaining, in your own words, 3 specific connected-speech features you've mastered (e.g., flap T, linking, schwa) and how they changed your spoken English.",
      "target_seconds": 250
    },
    "Tuesday": {
      "type": "teaching",
      "prompt": "Teach a Level 0 or Level 1 student one connected-speech feature you now consider automatic, breaking it down the way it was first taught to you.",
      "target_seconds": 250
    },
    "Wednesday": {
      "type": "improvisation",
      "prompt": "Respond to this unexpected prompt: read an unfamiliar short passage aloud cold (no preparation), then immediately self-critique your own connected speech.",
      "target_seconds": 250
    },
    "Thursday": {
      "type": "accent_mimicry",
      "prompt": "Find a challenging short clip (30-60 seconds) of very fast, natural native speech (a comedian, fast talker, or auctioneer-style speech). Attempt to mimic it as closely as possible.",
      "target_seconds": 250
    },
    "Friday": {
      "type": "free_mastery",
      "prompt": "Speak naturally for 5+ minutes on any topic, at your fastest comfortable natural speed, applying every connected-speech skill you've built since Level 0.",
      "target_seconds": 250
    }
  },
  "writing_prompts": [
    "Write a persuasive essay (300+ words, using rhetorical devices) arguing whether native-like pronunciation should be a required goal for advanced language learners.",
    "Write a critical analysis of your own accent journey, identifying which specific connected-speech features were hardest for you and why.",
    "Compose a formal report with recommendations for how future students at your level could learn connected speech more efficiently.",
    "Write a creative piece (story or poem) that plays with the sounds and rhythms of English itself as its central theme.",
    "Draft an opinion column about whether accent-reduction training reinforces harmful ideas about which accents are 'correct.'",
    "Write a comparison essay contrasting your native language's rhythm/stress system with English's stress-timed rhythm.",
    "Write freely about the moment you first felt genuinely fluent, or a moment you didn't — focus on style, not just content."
  ]
}
