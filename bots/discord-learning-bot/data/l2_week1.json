  "speaking_missions": {
    "Saturday": {
      "type": "debate",
      "prompt": "Debate: 'Social media has made news reporting worse, not better.' Argue for ONE side, using at least 2 pieces of evidence or examples.",
      "target_seconds": 190
    },
    "Sunday": {
      "type": "presentation",
      "prompt": "Give a 3-minute presentation on a current news story you've followed recently. Cover: what happened, why it matters, and your opinion on it.",
      "target_seconds": 190
    },
    "Monday": {
      "type": "analysis",
      "prompt": "Analyze why misinformation spreads so quickly online. Discuss at least 2 causes and 1 possible solution.",
      "target_seconds": 190
    },
    "Tuesday": {
      "type": "storytelling",
      "prompt": "Tell a detailed story about a time you found out important news — how did you hear about it, and how did you feel?",
      "target_seconds": 190
    },
    "Wednesday": {
      "type": "interview",
      "prompt": "Imagine you're a journalist being interviewed about press freedom. Answer these questions: Why does press freedom matter? What happens when it's restricted? Give one real or imagined example.",
      "target_seconds": 190
    },
    "Thursday": {
      "type": "summary",
      "prompt": "Summarize a news article or video you watched this week in your own words, in under 2 minutes, covering only the most important points.",
      "target_seconds": 190
    },
    "Friday": {
      "type": "free_discussion",
      "prompt": "Discuss freely for 4 minutes: how has the way people consume news changed in your lifetime? Consider newspapers, TV, and social media.",
      "target_seconds": 190
    }
  },
  "writing_prompts": [
    "Write an essay (150+ words) arguing whether social media has improved or damaged how people get news.",
    "Analyze how a major news event affected daily life in your country or city.",
    "Compare how the same news story is reported by two different sources you know (a local one and an international one).",
    "Write a formal email to a friend explaining why you trust (or don't trust) a particular news source, and why.",
    "Describe a personal experience related to hearing important breaking news (200+ words) — what were you doing, how did you find out, and how did you react?",
    "What changes would you make to how news is reported today? Explain at least 2 specific changes and why they would help.",
    "Summarize a news article about a current event in your own words, in under 150 words, without copying phrases from the original."
