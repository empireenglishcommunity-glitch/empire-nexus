  "speaking_missions": {
    "Saturday": {
      "type": "self_introduction",
      "prompt": "Talk about abilities: 'I can ___. I can't ___. I want to learn to ___.'",
      "target_seconds": 50
    },
    "Sunday": {
      "type": "describe",
      "prompt": "Describe a person you know using abilities and descriptions: what can they do?",
      "target_seconds": 50
    },
    "Monday": {
      "type": "list_count",
      "prompt": "List 5 things you can do and 3 things you can't do.",
      "target_seconds": 50
    },
    "Tuesday": {
      "type": "read_aloud",
      "prompt": "Read: 'I can speak Arabic quickly, but I can't speak English fast yet. It's difficult but not impossible. I practice carefully every day. I'm already better than last week.'",
      "target_seconds": 35
    },
    "Wednesday": {
      "type": "answer_questions",
      "prompt": "Answer: What can you do well? What is easy for you? What is difficult for you in English?",
      "target_seconds": 50
    },
    "Thursday": {
      "type": "shadow_repeat",
      "prompt": "Repeat 3 times: 'Can you swim? I can swim slowly but I can't run fast. It's really important to practice every day.'",
      "target_seconds": 30
    },
    "Friday": {
      "type": "free_talk",
      "prompt": "Talk for 55 seconds about skills: what you can do, what you want to learn, what is easy/hard.",
      "target_seconds": 55
    }
  },
  "writing_prompts": [
    "Write 5 things you can do and 3 you can't.",
    "Write: 'I can ___ quickly. I can't ___ well. It's difficult.'",
    "Describe yourself using adjectives (5 sentences).",
    "Write about something you want to learn: 'I can't ___ but I want to.'",
    "Write: 'Learning English is ___. It's ___ but possible.'",
    "Describe someone you admire: what can they do? (4 sentences).",
    "Write about your skills at work or school (5 sentences with can/can't)."
  ]
}