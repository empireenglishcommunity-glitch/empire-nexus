  "speaking_missions": {
    "Saturday": {
      "type": "debate",
      "prompt": "Debate: 'Globalization is destroying local cultures.' Argue for ONE side with 2 examples from your own experience or knowledge.",
      "target_seconds": 190
    },
    "Sunday": {
      "type": "presentation",
      "prompt": "Give a 3-minute presentation about a tradition or custom from your culture that outsiders often misunderstand.",
      "target_seconds": 190
    },
    "Monday": {
      "type": "analysis",
      "prompt": "Analyze why some traditions disappear over generations while others survive. Discuss at least 2 factors.",
      "target_seconds": 190
    },
    "Tuesday": {
      "type": "storytelling",
      "prompt": "Tell a detailed story about a festival or ceremony you attended that was meaningful to you.",
      "target_seconds": 190
    },
    "Wednesday": {
      "type": "interview",
      "prompt": "Imagine you're being interviewed about growing up between two cultures. Answer: What was the hardest part? What did you gain from it? What advice would you give others in that situation?",
      "target_seconds": 190
    },
    "Thursday": {
      "type": "summary",
      "prompt": "Summarize a documentary, article, or story you've encountered about a different culture, in under 2 minutes.",
      "target_seconds": 190
    },
    "Friday": {
      "type": "free_discussion",
      "prompt": "Discuss freely for 4 minutes: is it possible to fully understand a culture you weren't raised in? Why or why not?",
      "target_seconds": 190
    }
  },
  "writing_prompts": [
    "Write an essay (150+ words) arguing whether preserving traditions or modernizing society should be the higher priority.",
    "Analyze how globalization has changed a specific tradition or custom in your own country.",
    "Compare a wedding, festival, or ceremony from your culture with one from a different culture you know about.",
    "Write a formal email to a cultural exchange program explaining why you want to participate and what you hope to learn.",
    "Describe a personal experience of cultural shock or cultural misunderstanding (200+ words).",
    "What changes would you make to how your culture's traditions are passed to the next generation? Explain at least 2 specific ideas.",
    "Summarize an article or story about a cultural tradition from a country other than your own, in under 150 words."
  ]
