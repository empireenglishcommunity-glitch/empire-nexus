# Ghost Bot — Aegis Phase 6
# Copy this file to .env.ghost and fill in your values.
# NEVER commit .env.ghost to version control.
#
# This is a SEPARATE bot instance running the same code as the production
# bot, but with its own token, its own database, and a different command
# prefix (?). It lives in the same real guild but is restricted via Discord
# permissions to a hidden admin-only category.

# === REQUIRED ===
# The ghost bot's own Discord application token (NOT the production bot's).
# Register a separate application at https://discord.com/developers/applications
DISCORD_TOKEN=your_ghost_bot_token_here
GUILD_ID=1519797013565280446

# === DIFFERENT PREFIX (avoids collision with production bot's "!") ===
BOT_PREFIX=?

# === GHOST ISOLATION (Hisn D023 — REQUIRED, do not remove) ===
# Channel permission overwrites only isolate channel-scoped activity.
# Guild-wide events (on_member_join, reaction-based registration) and ALL
# scheduled background loops (morning DMs, streak alerts, daily digests,
# etc.) are NOT channel-scoped and will otherwise fire for real students
# and send them a second, uncoordinated set of DMs on top of the real
# bot's. This flag must be true here and ONLY here — never in the real
# production .env.
IS_GHOST_INSTANCE=true

# === AI (optional — ghost bot can run without AI, just uses fallbacks) ===
GEMINI_API_KEY=
GROQ_API_KEY=

# === SCHEDULING (same timezone, but tasks won't post since the ghost bot
#     only sees its own hidden admin category, not the real level channels) ===
DAILY_TASK_HOUR=6
TIMEZONE=Asia/Dubai

# === PRACTICE PLATFORM ===
PRACTICE_PLATFORM_URL=https://empire-practice-8l0.pages.dev

# === TELEGRAM ALERTS (disabled for ghost bot) ===
TELEGRAM_ALERT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# === OPERATIONAL ===
LOG_LEVEL=INFO
