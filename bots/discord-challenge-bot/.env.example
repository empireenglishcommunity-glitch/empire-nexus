# ============================================================
#  Empire Challenge Bot - Environment Variables
#  Copy this file to ".env" and fill in your own values.
#  The .env file is private and must NEVER be committed.
# ============================================================

# 1) Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=put-your-discord-bot-token-here

# 2) The Discord channel ID where the daily challenge is auto-posted
#    (right-click the channel -> Copy Channel ID, after enabling Developer Mode)
CHALLENGE_CHANNEL_ID=123456789012345678

# 3) Free AI key from https://console.groq.com (no credit card needed)
#    If you leave this empty the bot still works using built-in messages.
GROQ_API_KEY=

# 4) The hour (0-23, 24h format) to post the daily challenge. Default 9 = 9 AM.
DAILY_POST_HOUR=9

# 5) Your community timezone (e.g. Asia/Dubai, Africa/Cairo, Asia/Riyadh)
TIMEZONE=Asia/Dubai

# 6) OPTIONAL: the exact date the challenge starts (YYYY-MM-DD).
#    If empty, day 1 = the first day the bot runs.
START_DATE=

# 7) OPTIONAL: Telegram alerts when bot starts or stops.
#    Use @BotFather to create a bot (or reuse an existing one) and get the token.
#    Get your chat ID from @userinfobot.
#    If empty, no Telegram alerts are sent (bot works normally without them).
TELEGRAM_ALERT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
